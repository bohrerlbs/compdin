generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Role {
  MECANICO
  ENCARREGADO
  INSPETOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  nome         String
  trigrama     String   @unique  // 3 letras maiúsculas, ex: "LEO"
  matricula    String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(MECANICO)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")

  inspecoesAbertas       Inspecao[]           @relation("abertaPor")
  inspecoesFechadas      Inspecao[]           @relation("fechadaPor")
  subitemStatuses        SubitemStatus[]
  execucoesInspecionadas ExecucaoCartao[]     @relation("inspecionador")
  avisosEnviados         AvisoExecucao[]      @relation("avisosEnviados")
  defeitosRegistrados    DefeitoExecucao[]    @relation("defeitosRegistrados")
  procedimentos          ProcedimentoPadrao[]
  notificacoes           Notificacao[]
  pushSubscriptions      PushSubscription[]
  avisosGerais           AvisoGeral[]
  tarefasCriadas         TarefaCompdin[]    @relation("tarefasAutor")
  tarefasExecutadas      TarefaCompdin[]    @relation("tarefasResponsavel")

  @@map("users")
}

// ─── Tarefas COMPDIN (não-aeronáuticas) ──────────────────────────────────────

enum StatusTarefa {
  PENDENTE
  INICIADA
  CONCLUIDA
}

model TarefaCompdin {
  id            String       @id @default(cuid())
  titulo        String
  descricao     String?
  status        StatusTarefa @default(PENDENTE)
  autorId       String       @map("autor_id")
  responsavelId String?      @map("responsavel_id")
  iniciadoEm    DateTime?    @map("iniciado_em")
  concluidoEm   DateTime?    @map("concluido_em")
  criadoEm      DateTime     @default(now()) @map("criado_em")

  autor       User  @relation("tarefasAutor", fields: [autorId], references: [id])
  responsavel User? @relation("tarefasResponsavel", fields: [responsavelId], references: [id])

  @@map("tarefas_compdin")
}

// ─── Avisos Gerais ────────────────────────────────────────────────────────────

model AvisoGeral {
  id        String    @id @default(cuid())
  titulo    String
  corpo     String
  autorId   String    @map("autor_id")
  criadoEm  DateTime  @default(now()) @map("criado_em")
  editadoEm DateTime? @map("editado_em")
  expiresAt DateTime? @map("expires_at")

  autor User @relation(fields: [autorId], references: [id])

  @@map("avisos_gerais")
}

// ─── Notificações ─────────────────────────────────────────────────────────────

model Notificacao {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  tipo     String
  titulo   String
  corpo    String?
  lido     Boolean  @default(false)
  link     String?
  criadoEm DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificacoes")
}

// ─── Push Subscriptions ───────────────────────────────────────────────────────

model PushSubscription {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  endpoint String   @unique
  p256dh   String   @map("p256dh")
  auth     String
  criadoEm DateTime @default(now()) @map("criado_em")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── Procedimentos Padrão ─────────────────────────────────────────────────────

model ProcedimentoPadrao {
  id        String   @id @default(cuid())
  titulo    String
  descricao String?
  autorId   String   @map("autor_id")
  criadoEm  DateTime @default(now()) @map("criado_em")

  autor   User                 @relation(fields: [autorId], references: [id])
  imagens ProcedimentoImagem[]

  @@map("procedimentos_padrao")
}

model ProcedimentoImagem {
  id             String             @id @default(cuid())
  procedimentoId String             @map("procedimento_id")
  url            String
  legenda        String?
  ordem          Int                @default(0)

  procedimento ProcedimentoPadrao @relation(fields: [procedimentoId], references: [id], onDelete: Cascade)

  @@map("procedimento_imagens")
}

// ─── Aeronave ─────────────────────────────────────────────────────────────────

model Anv {
  id        String     @id @default(cuid())
  matricula String     @unique
  modelo    String     @default("H-60L")
  ativo     Boolean    @default(true)
  inspecoes Inspecao[]

  @@map("anvs")
}

// ─── Inspeção ─────────────────────────────────────────────────────────────────

enum InspecaoTipo {
  INSP_30D
  INSP_6M
  INSP_90D
  INSP_12M
  INSP_24M
  PMS_40
  PMS_120
  PMS_360
  PMI_480
  PMI_960
  EP1_ERO       // Inspeção Especial 1 — Atmosfera Erosiva
  EP2_POU       // Inspeção Especial 2 — Pouso Duro
  EP3_PAR       // Inspeção Especial 3 — Parada Brusca
  EP5_PRP       // Inspeção Especial 5 — PRP Atmosfera Erosiva
  INSP_ESPECIAL // Inspeção Especial (configurável pelo inspetor/encarregado)
}

enum InspecaoStatus {
  ABERTA
  CONCLUIDA
  CANCELADA
}

model Inspecao {
  id           String         @id @default(cuid())
  anvId        String         @map("anv_id")
  tipo         InspecaoTipo
  status       InspecaoStatus @default(ABERTA)
  abertaEm     DateTime       @default(now()) @map("aberta_em")
  abertaPorId  String         @map("aberta_por_id")
  fechadaEm    DateTime?      @map("fechada_em")
  fechadaPorId String?        @map("fechada_por_id")
  observacao   String?

  anv       Anv            @relation(fields: [anvId], references: [id])
  abertaPor User           @relation("abertaPor", fields: [abertaPorId], references: [id])
  fechadaPor User?         @relation("fechadaPor", fields: [fechadaPorId], references: [id])
  execucoes ExecucaoCartao[]

  @@map("inspecoes")
}

// ─── Catálogo ─────────────────────────────────────────────────────────────────

model Sistema {
  id          String       @id @default(cuid())
  codigo      String       @unique
  nomeEn      String       @map("nome_en")
  nomePt      String       @map("nome_pt")
  ordem       Int          @default(0)
  subsistemas Subsistema[]

  @@map("sistemas")
}

model Subsistema {
  id        String   @id @default(cuid())
  sistemaId String   @map("sistema_id")
  nomeEn    String   @map("nome_en")
  nomePt    String   @map("nome_pt")
  ordem     Int      @default(0)

  sistema Sistema  @relation(fields: [sistemaId], references: [id])
  cartoes Cartao[]

  @@map("subsistemas")
}

enum TipoCartao {
  VISUAL_CHECK
  DETAILED_INSPECTION
  SPECIAL_DETAILED_INSPECTION
  SERVICE
  LUBRIFICATION
  BIM_CHECK
  TAP_TEST
  OIL_SAMPLE
}

model Cartao {
  id           String     @id @default(cuid())
  subsistemaId String     @map("subsistema_id")
  codigo       String
  nomeEn       String     @map("nome_en")
  nomePt       String     @map("nome_pt")
  tipo         TipoCartao
  publicacao   String?
  wp           String?
  duracaoMin   Int?       @map("duracao_min")
  qtdRecursos  Int?       @map("qtd_recursos") @default(1)
  omDesignator String?    @map("om_designator")
  observacao   String?
  ordem        Int        @default(0)
  extra        Boolean    @default(false)

  subsistema    Subsistema          @relation(fields: [subsistemaId], references: [id])
  inspecaoTipos CartaoInspecaoTipo[]
  subitens      Subitem[]
  execucoes     ExecucaoCartao[]
  ferramentas   Ferramenta[]

  @@map("cartoes")
}

model CartaoInspecaoTipo {
  cartaoId     String       @map("cartao_id")
  inspecaoTipo InspecaoTipo @map("inspecao_tipo")

  cartao Cartao @relation(fields: [cartaoId], references: [id])

  @@id([cartaoId, inspecaoTipo])
  @@map("cartao_inspecao_tipos")
}

model Ferramenta {
  id            String  @id @default(cuid())
  cartaoId      String  @map("cartao_id")
  nome          String
  especificacao String?
  ordem         Int     @default(0)

  cartao Cartao @relation(fields: [cartaoId], references: [id])

  @@map("ferramentas")
}

// ─── Subitens ────────────────────────────────────────────────────────────────

model Subitem {
  id          String  @id @default(cuid())
  cartaoId    String  @map("cartao_id")
  letra       String
  descricaoPt String  @map("descricao_pt")
  descricaoEn String? @map("descricao_en")
  referencia  String?
  ordem       Int     @default(0)

  cartao   Cartao          @relation(fields: [cartaoId], references: [id])
  statuses SubitemStatus[]

  @@map("subitens")
}

// ─── Execução ─────────────────────────────────────────────────────────────────

model ExecucaoCartao {
  id              String    @id @default(cuid())
  inspecaoId      String    @map("inspecao_id")
  cartaoId        String    @map("cartao_id")
  // Inspector sign-off
  inspecionadoEm  DateTime? @map("inspecionado_em")
  inspecionadorId String?   @map("inspecionador_id")

  inspecao        Inspecao        @relation(fields: [inspecaoId], references: [id])
  cartao          Cartao          @relation(fields: [cartaoId], references: [id])
  inspecionador   User?           @relation("inspecionador", fields: [inspecionadorId], references: [id])
  subitemStatuses SubitemStatus[]
  avisos          AvisoExecucao[]
  defeitos        DefeitoExecucao[]

  @@unique([inspecaoId, cartaoId])
  @@map("execucoes_cartao")
}

// ─── Avisos (Encarregado/Inspetor → Mecânico) ────────────────────────────────

model AvisoExecucao {
  id        String    @id @default(cuid())
  execucaoId String   @map("execucao_id")
  autorId   String    @map("autor_id")
  texto     String
  criadoEm  DateTime  @default(now()) @map("criado_em")
  editadoEm DateTime? @map("editado_em")

  execucao ExecucaoCartao @relation(fields: [execucaoId], references: [id])
  autor    User           @relation("avisosEnviados", fields: [autorId], references: [id])
  leituras AvisoLeitura[]

  @@map("avisos_execucao")
}

model AvisoLeitura {
  avisoId   String   @map("aviso_id")
  userId    String   @map("user_id")
  lidoEm    DateTime @default(now()) @map("lido_em")

  aviso AvisoExecucao @relation(fields: [avisoId], references: [id])

  @@id([avisoId, userId])
  @@map("aviso_leituras")
}

// ─── Defeitos (Inspetor → Mecânico, reabre cartão) ────────────────────────────

model DefeitoExecucao {
  id          String    @id @default(cuid())
  execucaoId  String    @map("execucao_id")
  inspetorId  String    @map("inspetor_id")
  descricao   String
  criadoEm    DateTime  @default(now()) @map("criado_em")
  editadoEm   DateTime? @map("editado_em")
  resolvidoEm DateTime? @map("resolvido_em")

  execucao  ExecucaoCartao @relation(fields: [execucaoId], references: [id])
  inspetor  User           @relation("defeitosRegistrados", fields: [inspetorId], references: [id])

  @@map("defeitos_execucao")
}

enum StatusSubitem {
  PENDENTE
  INICIADA
  CONCLUIDA
}

model SubitemStatus {
  id               String        @id @default(cuid())
  execucaoId       String        @map("execucao_id")
  subitemId        String        @map("subitem_id")
  status           StatusSubitem @default(PENDENTE)
  mecanicoId       String?       @map("mecanico_id")
  dataInicio       DateTime?     @map("data_inicio")
  dataConclusao    DateTime?     @map("data_conclusao")
  observacao       String?
  observacaoAutorId String?      @map("observacao_autor_id")
  observacaoEm     DateTime?     @map("observacao_em")

  execucao          ExecucaoCartao @relation(fields: [execucaoId], references: [id])
  subitem           Subitem        @relation(fields: [subitemId], references: [id])
  mecanico          User?          @relation(fields: [mecanicoId], references: [id])

  @@unique([execucaoId, subitemId])
  @@map("subitem_statuses")
}
